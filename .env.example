# Soechi VMS — environment. Copy to `.env` (gitignored) for local dev; the inlined
# defaults in docker-compose.yml mean a bare `docker compose up` also works without one.
# For staging/prod (docker-compose.staging.yml) the secret vars are REQUIRED — set them.

# --- General -------------------------------------------------------------------
NODE_ENV=development

# --- Postgres ------------------------------------------------------------------
POSTGRES_USER=vms
POSTGRES_PASSWORD=vms
POSTGRES_DB=vms
POSTGRES_PORT=5432
# Used by services INSIDE the compose network (host = service name `postgres`).
# For running the app locally with `bun run dev` instead, use `localhost`:
#   DATABASE_URL=postgres://vms:vms@localhost:5432/vms
# (packages/db defaults to the localhost form when DATABASE_URL is unset.)

# --- MinIO (S3-compatible file storage, ADR-0008) -----------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=vms-documents
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# S3 endpoint as seen by the API (in-network default shown):
MINIO_ENDPOINT=http://minio:9000

# --- Mailpit (dev SMTP sink + web viewer for UAT account emails) --------------
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
# In dev the API sends through Mailpit:
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=no-reply@vms.local
# Staging/prod only — real SMTP credentials (Resend/SES/…):
# SMTP_USER=
# SMTP_PASS=

# --- App ports (host side) ----------------------------------------------------
API_PORT=3001
PORTAL_PORT=3000
CONSOLE_PORT=3002
# API base URL baked into the frontend bundles at build time (browser-visible):
VITE_API_URL=http://localhost:3001

# --- Staging/production overlay only ------------------------------------------
# Public URL the browser uses to reach the API (frontends compile against this):
# PUBLIC_API_URL=https://api.vms.example.com
# Registry image naming for `docker compose build`/push:
# IMAGE_PREFIX=ghcr.io/sinardyas/vms
# IMAGE_TAG=latest
